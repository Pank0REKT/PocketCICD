<Window x:Class="PocketCICD.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PocketCICD"
        Title="Pocket CI/CD" Height="925" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E" ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Height" Value="48" />
            <Setter Property="Margin" Value="0,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#CDD6F4" />
            <Setter Property="Background" Value="#313244" />
            <Setter Property="BorderBrush" Value="#45475A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#45475A" />
                                <Setter Property="BorderBrush" Value="#89B4FA" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#585B70" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PathLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="Foreground" Value="#6C7086" />
            <Setter Property="Margin" Value="4,0,0,4" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20" Orientation="Horizontal">
            <TextBlock Text="Pocket CI/CD"
                       FontSize="22" FontWeight="Bold"
                       FontFamily="Segoe UI"
                       Foreground="#CDD6F4" HorizontalAlignment="Left" />

            <Button Margin="10,0,0,0"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    ToolTip="Открыть репозиторий на GitHub"
                    Click="BtnGitHub_Click"
                    VerticalAlignment="Center">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="50">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#313244" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <Viewbox Width="22" Height="22" Margin="4">
                    <Path Fill="#6C7086"
                          Data="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385
                .6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235
                -3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695
                -.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23
                1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605
                -2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225
                -.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23
                .96-.27 1.98-.405 3-.405s2.04.135 3 .405
                c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18
                .765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925
                .435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3
                0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12
                c0-6.63-5.37-12-12-12z" />
                </Viewbox>
            </Button>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <TextBlock Text="Выберите сохраненный проект"
                       FontSize="12" Foreground="#6C7086"
                       FontFamily="Segoe UI" Margin="0,4,0,0" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ComboBox x:Name="ComboBoxProjects"
                          Grid.Column="0"
                          FontWeight="Bold"
                          FontFamily="Segoe UI"
                          Foreground="Black"
                          HorizontalContentAlignment="Left"
                          VerticalContentAlignment="Center"
                          SelectionChanged="ComboBoxProjects_SelectionChanged" />

                <Button Grid.Column="1"
                        Content="✕"
                        Width="32" Height="32"
                        Margin="6,0,0,0"
                        FontSize="13"
                        Foreground="#6C7086"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="Сбросить выбор"
                        Click="BtnClearComboBox_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#313244" />
                                    <Setter Property="Foreground" Value="#F38BA8" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="2">
            <StackPanel>
                <TextBlock Text="Настройте пути к директориям проекта"
                           FontSize="12" Foreground="#6C7086"
                           FontFamily="Segoe UI" Margin="0,4,0,0" />

                <Button Style="{StaticResource ModernButton}"
                        Click="BtnSourceProject_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📁" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <TextBlock Text="Исходный проект" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <TextBlock x:Name="LblSourceProject" Style="{StaticResource PathLabel}" Text="Путь не выбран" />
            </StackPanel>

            <StackPanel>
                <Button Style="{StaticResource ModernButton}"
                        Click="BtnTargetDir_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🎯" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <TextBlock Text="Целевая директория" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <TextBlock x:Name="LblTargetDir" Style="{StaticResource PathLabel}" Text="Путь не выбран" />
            </StackPanel>

            <StackPanel>
                <Button Style="{StaticResource ModernButton}"
                        Click="BtnBackup_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💾" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <TextBlock Text="Папка Backup" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <TextBlock x:Name="LblBackup" Style="{StaticResource PathLabel}" Text="Путь не выбран" />
            </StackPanel>

            <StackPanel>
                <Button Style="{StaticResource ModernButton}"
                        Click="BtnUpdate_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔄" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <TextBlock Text="Папка Update" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <TextBlock x:Name="LblUpdate" Style="{StaticResource PathLabel}" Text="Путь не выбран" />
            </StackPanel>

            <StackPanel>
                <Button Style="{StaticResource ModernButton}"
                        Click="BtnExclusions_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🚫" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <TextBlock Text="Файлы исключения  (папки / файлы)" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <ItemsControl x:Name="ListExclusions" Margin="4,0,0,4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       FontSize="11" FontFamily="Consolas"
                                       Foreground="#F38BA8" MaxHeight="25"
                                       TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock x:Name="LblExclusionsEmpty"
                           Style="{StaticResource PathLabel}"
                           Text="Ничего не выбрано" />
            </StackPanel>
            <StackPanel Margin="0,25,0,0">
                <Grid Height="25">
                    <ProgressBar x:Name="ProgressBar"  Minimum="0" Maximum="100" Value="0" Height="25" />
                    <TextBlock x:Name="ProgressBarTextBlock" HorizontalAlignment="Center" VerticalAlignment="Center">
                    </TextBlock>
                </Grid>
                
            </StackPanel>

        </StackPanel>

        <CheckBox x:Name="ChkLocalBackup"
                  Grid.Row="3"
                  Content="Сохранить локальный Backup"
                  Foreground="#CDD6F4"
                  FontFamily="Segoe UI"
                  FontSize="12"
                  Margin="0,12,0,0"
                  Cursor="Hand" />

        <Button Grid.Row="4"
                Content="Опубликовать"
                Height="36" Margin="0,16,0,6"
                FontSize="12" FontFamily="Segoe UI"
                Foreground="#A6E3A1"
                Background="Transparent"
                BorderBrush="#A6E3A1"
                BorderThickness="1"
                Cursor="Hand"
                Click="BtnPublish_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1" CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#1A2A1A" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <Grid Grid.Row="5" Margin="0,16,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Сохранить новый проект -->
            <Button Grid.Column="0"
                    Content="Сохранить проект"
                    Height="36"
                    FontSize="12" FontFamily="Segoe UI"
                    Foreground="#f0bd05"
                    Background="Transparent"
                    BorderBrush="#f0bd05"
                    BorderThickness="1"
                    Cursor="Hand"
                    Click="BtnSaveNew_OnClick">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2A1A" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Редактировать выбранный проект -->
            <Button Grid.Column="2"
                    x:Name="BtnEditProject"
                    Content="Редактировать"
                    Height="36"
                    FontSize="12" FontFamily="Segoe UI"
                    Foreground="#89B4FA"
                    Background="Transparent"
                    BorderBrush="#89B4FA"
                    BorderThickness="1"
                    Cursor="Hand"
                    IsEnabled="False"
                    Click="BtnEditProject_OnClick">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A1A2A" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <Button Grid.Row="6"
                Content="Сбросить все пути"
                Height="36" Margin="0,16,0,0"
                FontSize="12" FontFamily="Segoe UI"
                Foreground="#F38BA8"
                Background="Transparent"
                BorderBrush="#F38BA8"
                BorderThickness="1"
                Cursor="Hand"
                Click="BtnReset_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1" CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#2A1A1A" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</Window>